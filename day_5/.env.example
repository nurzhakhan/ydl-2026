# ============================================================
#  Скопируй этот файл в .env и впиши свои значения:
#     cp .env.example .env
#  .env в git НЕ попадёт (см. .gitignore).
# ============================================================

# --- Telegram ---
# Токен бота от @BotFather (https://t.me/BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# --- LLM (Gemma) ---
# Вариант A (по умолчанию): Google AI Studio.
#   Ключ берётся на https://aistudio.google.com/apikey (вид: AIza...)
#   Базовый URL и модель уже настроены ниже.
# Вариант B: OpenRouter / vLLM / другой OpenAI-совместимый хостинг —
#   поменяй LLM_BASE_URL и LLM_MODEL под своего провайдера.
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemma-3-27b-it
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
# Если провайдер ругается на роль "system" — поставь true
SYSTEM_AS_USER=false

# --- Embeddings (для RAG-поиска) ---
# Можно использовать тот же Google-ключ (модель text-embedding-004),
# либо отдельный ключ/провайдера.
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EMBEDDINGS_MODEL=text-embedding-004
EMBEDDINGS_BATCH_SIZE=32

# --- RAG (можно не трогать) ---
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=5
MIN_SCORE=0.25
# Приоритет свежести: новые страницы (по году в URL) поднимаются выше старых.
# 0 = выкл, 0.08 = умеренно.
RECENCY_WEIGHT=0.08
# Если в вопросе указан конкретный год («Data Lab 2019») — поднимаем этот год
# и отключаем приоритет свежести. 0 = выкл.
YEAR_MATCH_BOOST=0.15
# Приоритет ручной базы: твои файлы из data/raw_docs идут отдельным
# приоритетным тиром (бот смотрит сначала на них), если совпадают с вопросом
# по словам. MANUAL_MIN_SCORE — мягкий порог близости, MANUAL_RESERVE —
# сколько верхних мест резервируется под ручную базу.
MANUAL_MIN_SCORE=0.08
MANUAL_RESERVE=2
# Кросс-язык: переводить ручную базу на эти языки при сборке (нужен LLM-ключ).
# Тогда вопрос на RU/KZ/EN находит свою версию файла. Переводы кэшируются.
MANUAL_MULTILINGUAL=true
MANUAL_LANGUAGES=ru,kk,en

# --- Скрейпер сайта фонда (можно не трогать) ---
SITE_BASE_URL=https://yessenovfoundation.org
SCRAPE_MAX_PAGES=600
SCRAPE_TIMEOUT=30
# Разделы сайта, которые попадают в базу знаний (allowlist по первому
# сегменту пути). Раздел новостей сюда НЕ входит — он путает бота.
SITE_INCLUDE_SECTIONS=about-us,sh-esenov
# Исключить страницы, чей путь содержит эти подстроки (через запятую). Пусто = ничего.
SITE_EXCLUDE_PATHS=
